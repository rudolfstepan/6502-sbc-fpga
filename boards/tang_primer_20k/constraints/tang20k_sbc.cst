IO_LOC "DDR3_nCS" P5;
IO_PORT "DDR3_nCS" IO_TYPE=SSTL15 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=1.5;

// Keep the DDR memory PLL (now 99 MHz) on the same left-side site selected by
// the known-good Sipeed DDR test.  Without these constraints the full SBC design
// places the HDMI PLL at PLL_L[0] and moves DDR to PLL_R[0], adding a long
// cross-chip clock route that prevents PHY/DQS calibration.
// The DDR PLL line is only valid when USE_DDR3 or FB_DDR3 instantiates ddr_hw_g;
// comment it out for a pure BSRAM build.
INS_LOC "ddr_pll_i/rpll_inst" PLL_L[0] exclusive;
INS_LOC "hdmi_i/pll_i" PLL_R[0] exclusive;

// The SID rate enables are data/clock-enable pulses, not clocks. A CLOCK_LOC
// LOCAL_CLOCK on the SID tick net can keep it off scarce global routes, but the
// exact post-synthesis net path under the sid_g generate is elusive (CT1135), so
// it is left off — the SID works without it; re-add with the correct net name if
// the SID tick is seen stealing a primary clock route.
// CLOCK_LOC "sbc_i/.../sid_tick_pulse" LOCAL_CLOCK;
