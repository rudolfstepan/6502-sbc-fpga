IO_LOC "ddr_cs" P5;
IO_PORT "ddr_cs" IO_TYPE=SSTL15 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=1.5;

// Keep the 400 MHz DDR memory PLL on the same left-side site selected by the
// known-good Sipeed DDR test.  Without these constraints the full SBC design
// places the HDMI PLL at PLL_L[0] and moves DDR to PLL_R[0], adding a long
// cross-chip clock route that prevents PHY/DQS calibration.
INS_LOC "hdmi_i/pll_i" PLL_R[0] exclusive;

// The SID rate enables are data/clock-enable pulses, not clocks. Gowin may
// otherwise auto-promote their high-fanout nets to scarce PRIMARY/LW routes,
// reducing DDR clk_x1 coverage and making PHY calibration placement-dependent.
CLOCK_LOC "sbc_i/sid_i/sid_tick_pulse" LOCAL_CLOCK;
