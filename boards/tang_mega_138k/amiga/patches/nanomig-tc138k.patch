 // SB:
 // 2012-03-23 - fixed sprite enable signal (coppermaster demo)
 
-module minimig
+module minimig #(
+	parameter EXTERNAL_RAM_READ_WAIT = 1'b0
+)
 (
 	//m68k pins
 	input [23:1]  cpu_address, // m68k address bus
@@ -660,6 +662,25 @@ ciab CIAB1
 	.portb_out({_motor,_sel3,_sel2,_sel1,_sel0,side,direc,_step})
 );
 
+// The original asynchronous SRAM meets the first fixed DTACK point. Slower
+// board-local memory backends can request one additional 7 MHz read cycle.
+// ROM reads are excluded because the Console 138K serves Kickstart from BSRAM.
+reg external_ram_read_waited;
+// rd_cyc remains asserted at the CCK phase where the bridge samples nrdy;
+// ram_rd is intentionally deasserted in that phase and cannot qualify a wait.
+wire cpu_external_ram_read = rd_cyc &&
+                             ((|sel_chip) || (|sel_slow));
+wire external_ram_nrdy = EXTERNAL_RAM_READ_WAIT &&
+                         cpu_external_ram_read &&
+                         !external_ram_read_waited;
+
+always @(posedge clk) begin
+	if(reset || !cpu_external_ram_read)
+		external_ram_read_waited <= 1'b0;
+	else if(clk7n_en && cck && !(dbr && dbs))
+		external_ram_read_waited <= 1'b1;
+end
+
 //instantiate cpu bridge
 minimig_m68k_bridge CPU1 
 (
@@ -675,9 +696,9 @@ minimig_m68k_bridge CPU1
 	.dbs(dbs),
 	.xbs(xbs),
 `ifndef DISABLE_IDE
-	.nrdy(gayle_nrdy & rd_cyc),
-`else
-	.nrdy(1'b0),
+	.nrdy((gayle_nrdy & rd_cyc) | external_ram_nrdy),
+`else
+	.nrdy(external_ram_nrdy),
 `endif
 	.bls(bls),
 	.memory_config(memory_config[3:0]),
