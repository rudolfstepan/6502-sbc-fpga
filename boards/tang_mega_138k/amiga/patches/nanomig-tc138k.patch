+/* The Console 138K project embeds one 256 KiB Kickstart image in BSRAM.
+   The boot copier mirrors it into NanoMig's 512 KiB SDRAM ROM window. */
 
 // LED usage:
 // RGB led1, CFG:  G = ready, R = power/sys_act, B = done
@@ -124,15 +120,15 @@ assign leds[1] =  drv_leds[1] || drv_leds[0];
     Phase: 0.0°
   Output2:
     Freq: 85.0 Mhz
-    Phase: 216.0°
-  Output2:
+    Phase: shifted, see CLKOUT2_PE_COARSE/PE_FINE in gowin_pll/pll_142m_mod.v
+  Output3:
     Freq: 85.0 Mhz
-    Phase: 
+    Phase: 180.0°
 */
 
-// 180° barely boots, crashes early
-// 216° boots
-// 252° boots, DiagROM reports some rom checksum errors
+// clkout2 drives the SDRAM clock pin phase-shifted. The shift is board and
+// routing dependent and is tuned in gowin_pll/pll_142m_mod.v; the stock
+// value failed SDRAM readback here (magenta boot state).
 
 // Pixel clock if derived from 141 2/3 MHz
 `define PIXEL_CLOCK 28333333
@@ -144,13 +140,20 @@ wire pll_lock;
 pll_142m pll_hdmi (
     .clkout0(clk_pixel_x5),
     .clkout1(clk_85m),
-    .clkout2(clk_85m_shifted), // 216 deg phase shifted
+    .clkout2(clk_85m_shifted), // 270 deg phase shifted
     .clkout3(), //mspi_clk),        // 180 deg phase shifted
