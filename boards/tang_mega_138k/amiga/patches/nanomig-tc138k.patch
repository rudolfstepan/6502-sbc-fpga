diff --git a/src/tang/console138k/gowin_pll/pll_142m_mod.v b/src/tang/console138k/gowin_pll/pll_142m_mod.v
index 4a614bf..c48b176 100644
--- a/src/tang/console138k/gowin_pll/pll_142m_mod.v
+++ b/src/tang/console138k/gowin_pll/pll_142m_mod.v
@@ -120,8 +120,14 @@ defparam PLL_inst.CLKOUT0_PE_COARSE = 0;
 defparam PLL_inst.CLKOUT0_PE_FINE = 0;
 defparam PLL_inst.CLKOUT1_PE_COARSE = 0;
 defparam PLL_inst.CLKOUT1_PE_FINE = 0;
-defparam PLL_inst.CLKOUT2_PE_COARSE = 7;
-defparam PLL_inst.CLKOUT2_PE_FINE = 4;
+// SDRAM clock phase (CLKOUT2, ODIV 10: one PE_COARSE step = 36 deg, one
+// PE_FINE step = 4.5 deg). With READ_LATCH_DELAY=1 the ramtest sweep shows
+// a huge clean region (everything except 81..158 deg). 216 deg sits well
+// inside it and gives the read capture a couple of nanoseconds more setup
+// than the stock 270 deg: the chip returns its data earlier while the
+// capture clock stays put.
+defparam PLL_inst.CLKOUT2_PE_COARSE = 6;
+defparam PLL_inst.CLKOUT2_PE_FINE = 0;
 defparam PLL_inst.CLKOUT3_PE_COARSE = 5;
 defparam PLL_inst.CLKOUT3_PE_FINE = 0;
 defparam PLL_inst.CLKOUT4_PE_COARSE = 0;
diff --git a/src/tang/console138k/nanomig.sdc b/src/tang/console138k/nanomig.sdc
index bfa672d..fc21aa6 100644
--- a/src/tang/console138k/nanomig.sdc
+++ b/src/tang/console138k/nanomig.sdc
@@ -1,12 +1,27 @@
-create_clock -name clk_osc -period 20 -waveform {0 10} [get_ports {clk}] -add
-create_clock -name clk_companion_int -period 50 -waveform {0 25} [get_ports {spi_sclk}] -add
-create_clock -name clk85 -period 11.684 -waveform {0 5.848} [get_pins {pll_hdmi/u_pll/PLL_inst/CLKOUT1}] -add
-create_clock -name clk85_shift -period 11.684 -waveform {0 5.848} [get_pins {pll_hdmi/u_pll/PLL_inst/CLKOUT2}] -add
-create_clock -name clk_flash -period 11.684 -waveform {0 5.848} [get_ports {mspi_clk}] -add
-create_clock -name clk_hdmi -period 7 -waveform {0 3} [get_nets {clk_pixel_x5}] -add
-create_clock -name i2s_clk -period 500 -waveform {0 3} [get_nets {i2s_clk}] -add
-create_clock -name mcuclk -period 500 -waveform {0 3} [get_nets {mcu/n4_24}] -add
-create_clock -name clk_audio -period 500 -waveform {0 3} [get_nets {clk_audio}] -add
-create_generated_clock -name clk28 -source [get_pins {pll_hdmi/u_pll/PLL_inst/CLKOUT0}] -master_clock clk_hdmi -divide_by 5 [get_pins {clk_div_5/clkdiv_inst/CLKOUT}]
-set_multicycle_path -from [get_clocks {clk28}] -to [get_clocks {clk85}]  -setup -start 2
-set_multicycle_path -from [get_clocks {clk28}] -to [get_clocks {clk85}]  -hold -start 2
+create_clock -name clk_osc -period 20 -waveform {0 10} [get_ports {clk}] -add
+create_clock -name clk_companion_int -period 50 -waveform {0 25} [get_ports {spi_sclk}] -add
+create_clock -name clk85 -period 11.684 -waveform {0 5.848} [get_pins {pll_hdmi/u_pll/PLL_inst/CLKOUT1}] -add
+create_clock -name clk85_shift -period 11.684 -waveform {0 5.848} [get_pins {pll_hdmi/u_pll/PLL_inst/CLKOUT2}] -add
+create_clock -name clk_hdmi -period 7 -waveform {0 3} [get_nets {clk_pixel_x5}] -add
+create_clock -name mcuclk -period 500 -waveform {0 3} [get_nets {mcu/n4_24}] -add
+create_generated_clock -name clk28 -source [get_pins {pll_hdmi/u_pll/PLL_inst/CLKOUT0}] -master_clock clk_hdmi -divide_by 5 [get_pins {clk_div_5/clkdiv_inst/CLKOUT}]
+create_generated_clock -name i2s_clk -source [get_pins {clk_div_5/clkdiv_inst/CLKOUT}] -master_clock clk28 -divide_by 36 [get_nets {i2s_clk}]
+create_generated_clock -name clk_audio -source [get_pins {clk_div_5/clkdiv_inst/CLKOUT}] -master_clock clk28 -divide_by 590 [get_nets {clk_audio}]
+# clk28 and clk85 come from the same PLL, locked at exactly 1:3. The SDRAM
+# controller samples the sync strobe one 85 MHz clock after its 28 MHz launch
+# and the address one clock later, so every request signal must arrive within
+# a single 85 MHz period - a multicycle exception would allow P&R to build
+# routes the controller samples too late.
+set_max_delay -from [get_clocks {clk28}] -to [get_clocks {clk85}] 11
+# The read data is registered at 85 MHz 94 ns into the 141 ns bus slot and the
+# CPU bridge latches it at the 106 ns clk28 edge: bound the delivery instead
+# of false-pathing it, or P&R may route it slower than the 11.8 ns budget.
+set_max_delay -from [get_clocks {clk85}] -to [get_clocks {clk28}] 8
+# Only the quasi-static spi_ext flag still crosses from the oscillator domain.
+set_false_path -from [get_clocks {clk_osc}] -to [get_clocks {clk28}]
+set_false_path -from [get_clocks {clk_osc}] -to [get_clocks {mcuclk}]
+set_false_path -from [get_clocks {mcuclk}] -to [get_clocks {clk28}]
+set_false_path -from [get_clocks {clk28}] -to [get_clocks {mcuclk}]
+set_false_path -from [get_clocks {clk28}] -to [get_clocks {i2s_clk}]
+set_false_path -from [get_clocks {clk28}] -to [get_clocks {clk_audio}]
+set_false_path -from [get_clocks {clk_audio}] -to [get_clocks {clk28}]
