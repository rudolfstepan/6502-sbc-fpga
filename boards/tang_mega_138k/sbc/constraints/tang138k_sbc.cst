// On-board TF slot, full pinout confirmed against nand2mario's 486tang/NESTang
// console.cst (Tang Console 138K): CLK=V15 CMD=Y16 DAT0=AA15 DAT1=AB15
// DAT2=W14 DAT3=W15. sd_ncs is the SPI chip select = DAT3.
IO_LOC "sd_dclk" V15;
IO_PORT "sd_dclk" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
