// Buttons: F4 is the reset button in Sipeed examples, in a 1.5 V DDR bank.
// key[0] is treated as active-low in the top level, so it must idle high.
// key[1] is routed to a 3.3 V GPIO header pin for an external monitor button.
IO_LOC "key[0]" F4;
IO_PORT "key[0]" IO_TYPE=LVCMOS15 PULL_MODE=UP BANK_VCCIO=1.5;
IO_LOC "key[1]" P16;
IO_PORT "key[1]" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;

// Diagnostic outputs on free Tang Console PMOD0/LCD-DPI GPIOs. The old
// P19/R19/T21/U21 LED locations are dedicated CPU/SSPI pins in this package.
IO_LOC "led[0]" N18;
IO_PORT "led[0]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "led[1]" N19;
IO_PORT "led[1]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "led[2]" M18;
IO_PORT "led[2]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "led[3]" L18;
IO_PORT "led[3]" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;

// PS/2 keyboard and second SD-card SPI on spare 3.3 V GPIO header pins.
IO_LOC "ps2_clk" R17;
IO_PORT "ps2_clk" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;
IO_LOC "ps2_data" R18;
IO_PORT "ps2_data" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;

// Tang Console USB-A HID port 0, from Sipeed usb_hid_host_138k example.
// Low-speed USB bit-bang host: D+ / D- are bidirectional GPIOs.
// Disabled for the safe no-USB build: the last USB bring-up attempt made HDMI
// fail and the FPGA ran hot. Re-enable only together with a verified USB top.
//IO_LOC "usb_dp" H13;
//IO_PORT "usb_dp" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
//IO_LOC "usb_dm" G13;
//IO_PORT "usb_dm" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;

IO_LOC "sd2_dclk" T18;
IO_PORT "sd2_dclk" IO_TYPE=LVCMOS33 PULL_MODE=NONE DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "sd2_ncs" Y21;
IO_PORT "sd2_ncs" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "sd2_mosi" Y22;
IO_PORT "sd2_mosi" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "sd2_miso" AB21;
IO_PORT "sd2_miso" IO_TYPE=LVCMOS33 PULL_MODE=UP BANK_VCCIO=3.3;

// I2S/PT8211-style audio pins from Sipeed audio_i2s example.
IO_LOC "pa_en" AB16;
IO_PORT "pa_en" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "dac_din" AA16;
IO_PORT "dac_din" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "dac_ws" AB17;
IO_PORT "dac_ws" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8 BANK_VCCIO=3.3;
IO_LOC "dac_bck" Y17;
IO_PORT "dac_bck" IO_TYPE=LVCMOS33 PULL_MODE=UP DRIVE=8 BANK_VCCIO=3.3;

// DDR3 placement constraints -- active again since USE_DDR3 defaults to true
// (DDR3 + SDRAM0 framebuffer backends coexist, runtime-selected via $9007).
INS_LOC "hdmi_i/pll_i/PLL_inst" PLL_B[2];
INS_LOC "ddr_backend_g.ddr_mem_pll_i/u_pll/PLL_inst" PLL_L[0];
INS_LOC "ddr_backend_g.ddr3_ip_i/gw3_top/u_ddr_phy_top/u_dll" DDRDLLM_BL;
INS_LOC "ddr_backend_g.ddr3_ip_i/gw3_top/u_ddr_phy_top/fclkdiv" LEFTSIDE[4];
