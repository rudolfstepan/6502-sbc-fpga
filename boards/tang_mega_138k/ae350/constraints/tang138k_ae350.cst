// Hard block locations required by the AE350 reference design and the
// hardware-proven Tang Console DDR3 placement.
INS_LOC "u_Gowin_PLL_AE350/u_pll/PLL_inst" PLL_R[0];
INS_LOC "u_Gowin_PLL_DDR3/u_pll/PLL_inst" PLL_L[0];
INS_LOC "u_RiscV_AE350_SOC_Top/u_RiscV_AE350_SOC/u_riscv_ae350_ddr3_top/u_ddr3_memory_ahb_top/u_ddr3/gw3_top/u_ddr_phy_top/u_dll" DDRDLLM_BL;
