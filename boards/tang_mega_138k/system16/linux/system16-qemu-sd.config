# QEMU virt exposes the root filesystem as a virtio-mmio block device.
# The board-specific Gowin host remains enabled only in the hardware build.
# CONFIG_GORV32_SD is not set
# The shared SD DTS describes the physical FPGA framebuffer aperture, which
# does not exist on QEMU virt. Keep its driver unbound in this profile.
# CONFIG_FB_SIMPLE is not set
# CONFIG_GORV32_USB_HID is not set
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
