## Spartan-6 XC6SLX16 Development Board (PIX16) Constraints File
## Based on working demo project: 15_1_vga_test

NET "clk" LOC = T8 | TNM_NET = sys_clk_pin;
TIMESPEC TS_sys_clk_pin = PERIOD sys_clk_pin 50000 kHz;

NET "reset_n" LOC = L3 | IOSTANDARD = "LVCMOS33";

## VGA Output - Red Channel (5 bits)
NET "vga_out_r<4>" LOC = M13 | IOSTANDARD = "LVCMOS33";
NET "vga_out_r<3>" LOC = N14 | IOSTANDARD = "LVCMOS33";
NET "vga_out_r<2>" LOC = L12 | IOSTANDARD = "LVCMOS33";
NET "vga_out_r<1>" LOC = M12 | IOSTANDARD = "LVCMOS33";
NET "vga_out_r<0>" LOC = M11 | IOSTANDARD = "LVCMOS33";

## VGA Output - Green Channel (6 bits)
NET "vga_out_g<5>" LOC = P11 | IOSTANDARD = "LVCMOS33";
NET "vga_out_g<4>" LOC = M10 | IOSTANDARD = "LVCMOS33";
NET "vga_out_g<3>" LOC = L10 | IOSTANDARD = "LVCMOS33";
NET "vga_out_g<2>" LOC = P9  | IOSTANDARD = "LVCMOS33";
NET "vga_out_g<1>" LOC = N9  | IOSTANDARD = "LVCMOS33";
NET "vga_out_g<0>" LOC = M9  | IOSTANDARD = "LVCMOS33";

## VGA Output - Blue Channel (5 bits)
NET "vga_out_b<4>" LOC = L7 | IOSTANDARD = "LVCMOS33";
NET "vga_out_b<3>" LOC = N8 | IOSTANDARD = "LVCMOS33";
NET "vga_out_b<2>" LOC = P8 | IOSTANDARD = "LVCMOS33";
NET "vga_out_b<1>" LOC = M7 | IOSTANDARD = "LVCMOS33";
NET "vga_out_b<0>" LOC = P7 | IOSTANDARD = "LVCMOS33";

## VGA Sync Signals
NET "vga_out_vs" LOC = L13 | IOSTANDARD = "LVCMOS33";
NET "vga_out_hs" LOC = M14 | IOSTANDARD = "LVCMOS33";

## User Interface (from board demo 02_key_test)
NET "key<0>" LOC = C3 | IOSTANDARD = "LVCMOS33";
NET "key<1>" LOC = D3 | IOSTANDARD = "LVCMOS33";
NET "key<2>" LOC = E4 | IOSTANDARD = "LVCMOS33";
NET "key<3>" LOC = E3 | IOSTANDARD = "LVCMOS33";

NET "led<0>" LOC = P4 | IOSTANDARD = "LVCMOS33";
NET "led<1>" LOC = N5 | IOSTANDARD = "LVCMOS33";

## USB-UART (CH340C) — verified against demo 04_uart_test
NET "uart_tx" LOC = D12 | IOSTANDARD = "LVCMOS33";
NET "uart_rx" LOC = C11 | IOSTANDARD = "LVCMOS33";
