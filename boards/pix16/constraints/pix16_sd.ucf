## PIX16 SD card socket pins.
## Add this constraint file to an ISE implementation only when the selected
## top-level exposes these SD SPI signals.
##
## Source: pix16/demo/20_2_sd_sdram_an430_lcd/sd_sdram_an430_lcd.ucf

NET "sd_dclk" LOC = M3 | IOSTANDARD = "LVCMOS33"; ## SD CLK / SPI SCK
NET "sd_ncs"  LOC = N3 | IOSTANDARD = "LVCMOS33"; ## SD DAT3 / SPI CS
NET "sd_miso" LOC = L4 | IOSTANDARD = "LVCMOS33"; ## SD CMD / SPI DI to card
NET "sd_mosi" LOC = L5 | IOSTANDARD = "LVCMOS33"; ## SD DAT0 / SPI DO from card
