CONFIG VCCAUX = "3.3";

NET "clk_50mhz" LOC = "H17" | IOSTANDARD = LVCMOS33;
NET "clk_50mhz" TNM_NET = sys_clk_pin;
TIMESPEC TS_sys_clk_pin = PERIOD sys_clk_pin 20 ns HIGH 50 %;

NET "reset_btn" LOC = "N14" | IOSTANDARD = LVCMOS33 | PULLDOWN;

NET "led<0>" LOC = "V16" | IOSTANDARD = LVCMOS33 | DRIVE = 8 | SLEW = SLOW;
NET "led<1>" LOC = "U16" | IOSTANDARD = LVCMOS33 | DRIVE = 8 | SLEW = SLOW;

NET "tmds<0>"  LOC = "T6" | IOSTANDARD = TMDS_33;
NET "tmdsb<0>" LOC = "V6" | IOSTANDARD = TMDS_33;
NET "tmds<1>"  LOC = "U7" | IOSTANDARD = TMDS_33;
NET "tmdsb<1>" LOC = "V7" | IOSTANDARD = TMDS_33;
NET "tmds<2>"  LOC = "U8" | IOSTANDARD = TMDS_33;
NET "tmdsb<2>" LOC = "V8" | IOSTANDARD = TMDS_33;
NET "tmds<3>"  LOC = "U5" | IOSTANDARD = TMDS_33;
NET "tmdsb<3>" LOC = "V5" | IOSTANDARD = TMDS_33;
