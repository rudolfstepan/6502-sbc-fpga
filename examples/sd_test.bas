10 REM --- test sector 1 (slot 0 with +1 offset) ---
20 REM CMD=34852 STAT=34853 SECT0..3=34854..57
30 REM DATA=34858 DPTRL=34859 DPTRH=34860
40 REM write test pattern to sector 1
50 POKE 34859,0:POKE 34860,0
60 POKE 34858,11:POKE 34858,22:POKE 34858,33:POKE 34858,44
70 POKE 34854,1:POKE 34855,0:POKE 34856,0:POKE 34857,0
80 POKE 34852,2
90 IF (PEEK(34853) AND 1)=1 THEN 90
100 PRINT "WR1 STATUS=";PEEK(34853)
110 REM clear buffer
120 POKE 34859,0:POKE 34860,0
130 POKE 34858,0:POKE 34858,0:POKE 34858,0:POKE 34858,0
140 REM read sector 1 back
150 POKE 34854,1:POKE 34855,0:POKE 34856,0:POKE 34857,0
160 POKE 34852,1
170 IF (PEEK(34853) AND 1)=1 THEN 170
180 PRINT "RD1 STATUS=";PEEK(34853)
190 POKE 34859,0:POKE 34860,0
200 PRINT "SECT1 GOT ";PEEK(34858);PEEK(34858);PEEK(34858);PEEK(34858)
210 PRINT "WANT     11 22 33 44"
