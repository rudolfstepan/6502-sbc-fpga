1 REM ====================================
2 REM  NATIVE SID6581 DEMO - FPGA
3 REM  SID REGISTERS $D400-$D418
4 REM ====================================
5 REM VOICE BLOCKS: $D400,$D407,$D40E
6 REM +0/+1 FREQ  +2/+3 PULSE  +4 CONTROL
7 REM +5 ATTACK/DECAY  +6 SUSTAIN/RELEASE
8 REM CONTROL: TRI=16 SAW=32 PULSE=64 NOISE=128
9 REM BIT 0 IS GATE. $D418 LOW NIBBLE IS VOLUME.
10 BA=54272:V0=BA:V1=BA+7:V2=BA+14
11 TM=15:GP=120:CV=17.028
12 FOR I=0 TO 24:POKE BA+I,0:NEXT
13 POKE BA+24,15
14 REM SET 50 PERCENT PULSE WIDTH ON ALL VOICES
15 POKE V0+2,0:POKE V0+3,8
16 POKE V1+2,0:POKE V1+3,8
17 POKE V2+2,0:POKE V2+3,8
20 PRINT "===================================="
30 PRINT " NATIVE SID6581 ADSR DEMO - $D400"
40 PRINT "===================================="
50 PRINT
60 PRINT "PRESS A KEY TO START"
70 GOSUB 950
80 PRINT
100 PRINT "1) FLAT TRIANGLE"
110 AD=0:SR=240:WF=16:GOSUB 700:GOSUB 800
120 PRINT "   PRESS A KEY...":GOSUB 950
130 PRINT
140 PRINT "2) PIANO PULSE"
150 AD=2:SR=137:WF=64:GOSUB 700:GOSUB 800
160 PRINT "   PRESS A KEY...":GOSUB 950
170 PRINT
180 PRINT "3) STRINGS SAWTOOTH"
190 AD=132:SR=203:WF=32:GOSUB 700:GOSUB 800
200 PRINT "   PRESS A KEY...":GOSUB 950
210 PRINT
220 PRINT "4) ORGAN TRIANGLE"
230 AD=17:SR=229:WF=16:GOSUB 700:GOSUB 800
240 PRINT "   PRESS A KEY...":GOSUB 950
250 PRINT
300 PRINT "--- 3-VOICE SID CHORD (C-E-G) ---"
310 AD=36:SR=169
320 POKE V0+5,AD:POKE V0+6,SR
330 POKE V1+5,AD:POKE V1+6,SR
340 POKE V2+5,AD:POKE V2+6,SR
350 F=523:VV=V0:GOSUB 880
360 F=659:VV=V1:GOSUB 880
370 F=784:VV=V2:GOSUB 880
380 POKE V0+4,32:POKE V1+4,32:POKE V2+4,32
390 POKE V0+4,33:POKE V1+4,33:POKE V2+4,33
400 FOR T=1 TO 1500*TM:NEXT
410 POKE V0+4,32:POKE V1+4,32:POKE V2+4,32
420 FOR T=1 TO GP*TM:NEXT
430 PRINT "   PRESS A KEY...":GOSUB 950
440 PRINT
500 PRINT "===================================="
510 PRINT " TETRIS THEME - SID PULSE VOICE"
520 PRINT "===================================="
530 AD=2:SR=137:WF=64:GOSUB 700
540 RESTORE
550 READ F:IF F<0 THEN 600
560 READ DM:GOSUB 900
570 GOTO 550
600 POKE V0+4,0:POKE V1+4,0:POKE V2+4,0
610 POKE BA+24,0
620 PRINT "DEMO COMPLETE. THANK YOU!"
630 END
699 REM === SET VOICE 0 ENVELOPE ===
700 POKE V0+4,0:POKE V0+5,AD:POKE V0+6,SR
710 RETURN
799 REM === PLAY C-E-G-C ARPEGGIO ===
800 F=523:DM=600:GOSUB 900
810 F=659:DM=600:GOSUB 900
820 F=784:DM=600:GOSUB 900
830 F=1047:DM=900:GOSUB 900
840 RETURN
879 REM === WRITE SID FREQUENCY (F=HZ,VV=VOICE) ===
880 FR=INT(F*CV)
890 POKE VV,FR AND 255:POKE VV+1,INT(FR/256)
895 RETURN
899 REM === PLAY VOICE 0 NOTE (F=HZ,DM=MS) ===
900 ND=DM-GP:IF ND<60 THEN ND=60
905 POKE V0+4,WF
910 VV=V0:GOSUB 880
920 POKE V0+4,WF+1
930 FOR T=1 TO ND*TM:NEXT
935 POKE V0+4,WF
940 FOR T=1 TO GP*TM:NEXT
945 RETURN
949 REM === WAIT FOR A KEYPRESS ===
950 GET K$:IF K$="" THEN 950
960 RETURN
1000 REM === TETRIS MELODY: HZ,DURATION MS ===
1010 DATA 659,500,494,250,523,250,587,500,523,250,494,250
1020 DATA 440,500,440,250,523,250,659,500,587,250,523,250
1030 DATA 494,750,523,250,587,500,659,500,523,500,440,500
1040 DATA 440,1000,587,750,698,250,880,500,784,250,698,250
1050 DATA 659,750,523,250,659,500,587,250,523,250,494,500
1060 DATA 494,250,523,250,587,500,659,500,523,500,440,500
1070 DATA 440,1000
1080 DATA -1,0
