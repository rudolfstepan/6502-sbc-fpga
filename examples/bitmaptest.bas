5 REM *** FPGA VIC BITMAP MODE TEST ***
10 REM 320X200, 1 BIT/PIXEL, 16 COLORS
15 REM BITMAP RAM $6000-$7FFF, PIXELS TO $7F3F
20 DIM M(7)
25 M(0)=128:M(1)=64:M(2)=32:M(3)=16
30 M(4)=8:M(5)=4:M(6)=2:M(7)=1
35 BM=24576:CM=33792
100 REM === CLEAR BITMAP AND COLOR RAM ===
110 FOR I=0 TO 7999:POKE BM+I,0:NEXT
120 FOR I=0 TO 999:POKE CM+I,1:NEXT
130 POKE 36864,1
200 REM === BORDER ===
210 FOR I=0 TO 39
220 POKE BM+I,255:POKE BM+199*40+I,255
230 NEXT
240 FOR I=0 TO 199
250 POKE BM+I*40,PEEK(BM+I*40) OR 128
260 POKE BM+I*40+39,PEEK(BM+I*40+39) OR 1
270 NEXT
300 REM === DIAGONALS ===
310 FOR I=0 TO 199
320 X=I*319/199:Y=I:GOSUB 900
330 X=319-I*319/199:Y=I:GOSUB 900
340 NEXT
400 REM === FILLED BOX (120,60)-(199,139) ===
410 FOR Y=60 TO 139
420 FOR X=120 TO 199
430 GOSUB 900
440 NEXT:NEXT
500 REM === COLOR QUADRANTS ===
510 FOR R=0 TO 24:FOR C=0 TO 39
520 CO=1
530 IF R<12 AND C<20 THEN CO=2
540 IF R<12 AND C>19 THEN CO=5
550 IF R>11 AND C<20 THEN CO=6
560 IF R>11 AND C>19 THEN CO=7
570 POKE CM+R*40+C,CO
580 NEXT:NEXT
590 REM BOX COLOR: WHITE ON PURPLE
600 FOR R=7 TO 17:FOR C=15 TO 24
610 POKE CM+R*40+C,65
620 NEXT:NEXT
700 REM === WAIT FOR KEY, RETURN TO TEXT ===
710 GET K$:IF K$="" THEN 710
720 POKE 36864,0
730 END
900 REM === SET PIXEL (X,Y) ===
910 A=BM+Y*40+INT(X/8)
920 POKE A,PEEK(A) OR M(X AND 7)
930 RETURN
