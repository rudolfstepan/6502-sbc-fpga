0002C7r 1  D0 F7            bne     ci_col
0002C9r 1  18               clc
0002CAr 1  A5 02            lda     ZP_CUR_LO
0002CCr 1  69 28            adc     #40
0002CEr 1  85 02            sta     ZP_CUR_LO
0002D0r 1  90 02            bcc     ci_no_carry
0002D2r 1  E6 03            inc     ZP_CUR_HI
0002D4r 1               ci_no_carry:
0002D4r 1  CA               dex
0002D5r 1  D0 E7            bne     ci_row
0002D7r 1               
0002D7r 1                   ; reset cursor to row 9
0002D7r 1  A9 68            lda     #<INPUT_ROW
0002D9r 1  85 02            sta     ZP_CUR_LO
0002DBr 1  A9 81            lda     #>INPUT_ROW
0002DDr 1  85 03            sta     ZP_CUR_HI
