Main file   : rom_demo.s
Current file: rom_demo.s

000000r 1               ; ============================================================
000000r 1               ; rom_demo.s  -  6502 SBC ROM: VGA welcome screen + serial keyboard
000000r 1               ;
000000r 1               ; ROM: 2 KB at $F800-$FFFF
000000r 1               ; Reset entry:  $F800
000000r 1               ; IRQ handler:  irq_handler
000000r 1               ;
000000r 1               ; Hardware:
000000r 1               ;   VIC text RAM  $8000-$87FF  (40x25 chars)
000000r 1               ;   VIA 6522      $8800-$880F  (Timer 1 IRQ, Port B -> LEDs)
000000r 1               ;   UART 6551     $8810-$8813  (RX keyboard, TX echo)
000000r 1               ;
000000r 1               ; Screen layout:
000000r 1               ;   Row 2:  "  **** 6502 SINGLE BOARD COMPUTER ****  "
000000r 1               ;   Row 4:  " 4096 BYTES RAM     2048 BYTES ROM     "
000000r 1               ;   Row 6:  "BEREIT."
000000r 1               ;   Row 8:  "VIA-T1:  00"   (live tick counter, updated ~3Hz by ISR)
000000r 1               ;   Row 9-24: input area (keyboard echo, wraps and clears on overflow)
000000r 1               ;
000000r 1               ; VIA Timer 1: free-running, period $FFFF (~1.3 ms @ 50 MHz).
000000r 1               ; Every 256th IRQ (~330 ms): increment tick counter, update row 8, blink LED.
000000r 1               ;
000000r 1               ; Main loop: poll UART RX (status $8811 bit 3 = RDRF).
000000r 1               ; On char received: echo back via TX ($8810 write), display on VIC screen.
000000r 1               ; Backspace ($08/$7F) erases last char. CR/LF advances to next line.
000000r 1               ; Input area wraps (clear + restart) when row 24 is full.
000000r 1               ;
000000r 1               ; Build:
000000r 1               ;   ca65 --cpu 6502 -t none -l rom_demo.lst rom_demo.s -o rom_demo.o
000000r 1               ;   ld65 -C rom_demo.cfg -o rom_demo.bin rom_demo.o -m rom_demo.map
000000r 1               ;   python bin_to_fpga_hex.py rom_demo.bin 0xF800 0x0800 ../sim/rom_welcome.hex
000000r 1               ; ============================================================
000000r 1               
000000r 1               ; ---- Hardware addresses ----
000000r 1               VIC_BASE    = $8000
000000r 1               
000000r 1               VIA_ORB     = $8800
000000r 1               VIA_DDRB    = $8802
000000r 1               VIA_T1CL    = $8804
000000r 1               VIA_T1CH    = $8805
000000r 1               VIA_T1LL    = $8806
000000r 1               VIA_T1LH    = $8807
000000r 1               VIA_ACR     = $880B
000000r 1               VIA_IER     = $880E
000000r 1               
000000r 1               UART_DATA   = $8810         ; read = RX byte (clears RDRF), write = TX byte
000000r 1               UART_STATUS = $8811         ; bit 3 = RDRF (data available), bit 4 = TDRE
000000r 1               UART_RDRF   = $08
000000r 1               UART_TDRE   = $10
000000r 1               
000000r 1               ; ---- Screen row addresses ----
000000r 1               ROW0        = VIC_BASE + 0 * 40     ; $8000
000000r 1               ROW1        = VIC_BASE + 1 * 40     ; $8028
000000r 1               ROW2        = VIC_BASE + 2 * 40     ; $8050
000000r 1               ROW3        = VIC_BASE + 3 * 40     ; $8078
000000r 1               ROW4        = VIC_BASE + 4 * 40     ; $80A0
000000r 1               ROW5        = VIC_BASE + 5 * 40     ; $80C8
000000r 1               ROW6        = VIC_BASE + 6 * 40     ; $80F0
000000r 1               ROW7        = VIC_BASE + 7 * 40     ; $8118
000000r 1               ROW8        = VIC_BASE + 8 * 40     ; $8140
000000r 1               
000000r 1               ; Input area: rows 9-24
000000r 1               INPUT_ROW   = VIC_BASE + 9 * 40     ; $8168 - first input row
000000r 1               INPUT_END   = VIC_BASE + 25 * 40    ; $83E8 - first byte past row 24
000000r 1               
000000r 1               ; Column offsets in row 8 for the tick counter: "VIA-T1:  00"
000000r 1               VIA_HI      = ROW8 + 9             ; $8149  high nibble
000000r 1               VIA_LO      = ROW8 + 10            ; $814A  low nibble
000000r 1               
000000r 1               ; ---- Zero page ----
000000r 1               ZP_FAST     = $00   ; ISR fast divider (wraps every 256 ~ 330 ms)
000000r 1               ZP_TICK     = $01   ; display tick counter
000000r 1               ZP_CUR_LO   = $02   ; cursor: VRAM row-start address low
000000r 1               ZP_CUR_HI   = $03   ; cursor: VRAM row-start address high
000000r 1               ZP_COL      = $04   ; cursor: current column (0-39)
000000r 1               ZP_STR_LO   = $05   ; print_str source pointer low
000000r 1               ZP_STR_HI   = $06   ; print_str source pointer high
000000r 1               ZP_TMP      = $07   ; self-test scratch/save byte
000000r 1               
000000r 1               ; ---- Self-test probe addresses ----
000000r 1               RAM_PROBE   = $0200
000000r 1               STK_PROBE   = $0180
000000r 1               VRAM_PROBE  = INPUT_ROW
000000r 1               
000000r 1               ; ============================================================
000000r 1               .segment "CODE"
000000r 1               
000000r 1               ; ============================================================
000000r 1               ;  RESET  ($F800)
000000r 1               ; ============================================================
000000r 1               reset:
000000r 1  78               sei
000001r 1  D8               cld
000002r 1  A2 FF            ldx     #$FF
000004r 1  9A               txs
000005r 1               
000005r 1                   ; clear ZP variables
000005r 1  A9 00            lda     #$00
000007r 1  85 00            sta     ZP_FAST
000009r 1  85 01            sta     ZP_TICK
00000Br 1  85 04            sta     ZP_COL
00000Dr 1               
00000Dr 1                   ; cursor starts at row 9 ($8168)
00000Dr 1  A9 68            lda     #<INPUT_ROW
00000Fr 1  85 02            sta     ZP_CUR_LO
000011r 1  A9 81            lda     #>INPUT_ROW
000013r 1  85 03            sta     ZP_CUR_HI
000015r 1               
000015r 1                   ; VIA Port B: all output, start at $00
000015r 1  A9 FF            lda     #$FF
000017r 1  8D 02 88         sta     VIA_DDRB
00001Ar 1  A9 00            lda     #$00
00001Cr 1  8D 00 88         sta     VIA_ORB
00001Fr 1               
00001Fr 1                   ; VIA Timer 1: free-running, period $FFFF
00001Fr 1  A9 40            lda     #$40
000021r 1  8D 0B 88         sta     VIA_ACR
000024r 1  A9 FF            lda     #$FF
000026r 1  8D 06 88         sta     VIA_T1LL
000029r 1  8D 07 88         sta     VIA_T1LH
00002Cr 1  8D 05 88         sta     VIA_T1CH
00002Fr 1               
00002Fr 1                   ; enable VIA Timer 1 IRQ
00002Fr 1  A9 C0            lda     #$C0
000031r 1  8D 0E 88         sta     VIA_IER
000034r 1               
000034r 1                   ; draw welcome screen
000034r 1  20 rr rr         jsr     draw_screen
000037r 1               
000037r 1                   ; clear input area (rows 9-24) and reset cursor
000037r 1  20 rr rr         jsr     clear_input
00003Ar 1               
00003Ar 1                   ; send reset/debug state to host console before interrupts start
00003Ar 1  20 rr rr         jsr     print_debug
00003Dr 1  20 rr rr         jsr     system_check
000040r 1               
000040r 1                   ; start CPU interrupts
000040r 1  58               cli
000041r 1               
000041r 1               ; ============================================================
000041r 1               ;  MAIN LOOP — poll UART for keyboard input
000041r 1               ; ============================================================
000041r 1               main_loop:
000041r 1  AD 11 88         lda     UART_STATUS
000044r 1  29 08            and     #UART_RDRF
000046r 1  F0 F9            beq     main_loop       ; no data
000048r 1               
000048r 1  AD 10 88         lda     UART_DATA       ; read byte (clears RDRF)
00004Br 1  20 rr rr         jsr     put_char        ; display on VIC
00004Er 1  4C rr rr         jmp     main_loop
000051r 1               
000051r 1               ; ============================================================
000051r 1               ;  UART DEBUG OUTPUT
000051r 1               ; ============================================================
000051r 1               
000051r 1               print_char:
000051r 1  48               pha
000052r 1               pd_tdre:
000052r 1  AD 11 88         lda     UART_STATUS
000055r 1  29 10            and     #UART_TDRE
000057r 1  F0 F9            beq     pd_tdre
000059r 1  68               pla
00005Ar 1  8D 10 88         sta     UART_DATA
00005Dr 1  60               rts
00005Er 1               
00005Er 1               print_crlf:
00005Er 1  A9 0D            lda     #$0D
000060r 1  20 rr rr         jsr     print_char
000063r 1  A9 0A            lda     #$0A
000065r 1  4C rr rr         jmp     print_char
000068r 1               
000068r 1               print_str:
000068r 1  A0 00            ldy     #$00
00006Ar 1               ps_loop:
00006Ar 1  B1 05            lda     (ZP_STR_LO),y
00006Cr 1  F0 06            beq     ps_done
00006Er 1  20 rr rr         jsr     print_char
000071r 1  C8               iny
000072r 1  D0 F6            bne     ps_loop
000074r 1               ps_done:
000074r 1  60               rts
000075r 1               
000075r 1               print_hex:
000075r 1  48               pha
000076r 1  4A               lsr
000077r 1  4A               lsr
000078r 1  4A               lsr
000079r 1  4A               lsr
00007Ar 1  AA               tax
00007Br 1  BD rr rr         lda     hex_table,x
00007Er 1  20 rr rr         jsr     print_char
000081r 1  68               pla
000082r 1  29 0F            and     #$0F
000084r 1  AA               tax
000085r 1  BD rr rr         lda     hex_table,x
000088r 1  4C rr rr         jmp     print_char
00008Br 1               
00008Br 1               print_msg:
00008Br 1  85 05            sta     ZP_STR_LO
00008Dr 1  86 06            stx     ZP_STR_HI
00008Fr 1  4C rr rr         jmp     print_str
000092r 1               
000092r 1               print_debug:
000092r 1  AD 11 88         lda     UART_STATUS
000095r 1  48               pha
000096r 1               
000096r 1  A9 rr            lda     #<str_dbg_reset
000098r 1  A2 rr            ldx     #>str_dbg_reset
00009Ar 1  20 rr rr         jsr     print_msg
00009Dr 1               
00009Dr 1  A9 rr            lda     #<str_dbg_map
00009Fr 1  A2 rr            ldx     #>str_dbg_map
0000A1r 1  20 rr rr         jsr     print_msg
0000A4r 1               
0000A4r 1  A9 rr            lda     #<str_dbg_uart
0000A6r 1  A2 rr            ldx     #>str_dbg_uart
0000A8r 1  20 rr rr         jsr     print_msg
0000ABr 1  68               pla
0000ACr 1  20 rr rr         jsr     print_hex
0000AFr 1  20 rr rr         jsr     print_crlf
0000B2r 1               
0000B2r 1  A9 rr            lda     #<str_dbg_via
0000B4r 1  A2 rr            ldx     #>str_dbg_via
0000B6r 1  20 rr rr         jsr     print_msg
0000B9r 1  AD 0B 88         lda     VIA_ACR
0000BCr 1  20 rr rr         jsr     print_hex
0000BFr 1  A9 rr            lda     #<str_dbg_ier
0000C1r 1  A2 rr            ldx     #>str_dbg_ier
0000C3r 1  20 rr rr         jsr     print_msg
0000C6r 1  AD 0E 88         lda     VIA_IER
0000C9r 1  20 rr rr         jsr     print_hex
0000CCr 1  A9 rr            lda     #<str_dbg_t1
0000CEr 1  A2 rr            ldx     #>str_dbg_t1
0000D0r 1  20 rr rr         jsr     print_msg
0000D3r 1               
0000D3r 1  A9 rr            lda     #<str_dbg_zp
0000D5r 1  A2 rr            ldx     #>str_dbg_zp
0000D7r 1  20 rr rr         jsr     print_msg
0000DAr 1  A5 00            lda     ZP_FAST
0000DCr 1  20 rr rr         jsr     print_hex
0000DFr 1  A9 20            lda     #$20
0000E1r 1  20 rr rr         jsr     print_char
0000E4r 1  A5 01            lda     ZP_TICK
0000E6r 1  20 rr rr         jsr     print_hex
0000E9r 1  A9 20            lda     #$20
0000EBr 1  20 rr rr         jsr     print_char
0000EEr 1  A5 03            lda     ZP_CUR_HI
0000F0r 1  20 rr rr         jsr     print_hex
0000F3r 1  A5 02            lda     ZP_CUR_LO
0000F5r 1  20 rr rr         jsr     print_hex
0000F8r 1  A9 20            lda     #$20
0000FAr 1  20 rr rr         jsr     print_char
0000FDr 1  A5 04            lda     ZP_COL
0000FFr 1  20 rr rr         jsr     print_hex
000102r 1  20 rr rr         jsr     print_crlf
000105r 1               
000105r 1  A9 rr            lda     #<str_dbg_ready
000107r 1  A2 rr            ldx     #>str_dbg_ready
000109r 1  4C rr rr         jmp     print_msg
00010Cr 1               
00010Cr 1               ; ============================================================
00010Cr 1               ;  RESET SYSTEM CHECK
00010Cr 1               ; ============================================================
00010Cr 1               
00010Cr 1               system_check:
00010Cr 1  A9 rr            lda     #<str_chk_head
00010Er 1  A2 rr            ldx     #>str_chk_head
000110r 1  20 rr rr         jsr     print_msg
000113r 1  20 rr rr         jsr     check_zp
000116r 1  20 rr rr         jsr     check_stack
000119r 1  20 rr rr         jsr     check_ram
00011Cr 1  20 rr rr         jsr     check_vram
00011Fr 1  20 rr rr         jsr     check_via
000122r 1  20 rr rr         jsr     check_uart
000125r 1  A9 rr            lda     #<str_chk_done
000127r 1  A2 rr            ldx     #>str_chk_done
000129r 1  4C rr rr         jmp     print_msg
00012Cr 1               
00012Cr 1               print_ok:
00012Cr 1  A9 rr            lda     #<str_ok
00012Er 1  A2 rr            ldx     #>str_ok
000130r 1  4C rr rr         jmp     print_msg
000133r 1               
000133r 1               print_fail:
000133r 1  A9 rr            lda     #<str_fail
000135r 1  A2 rr            ldx     #>str_fail
000137r 1  4C rr rr         jmp     print_msg
00013Ar 1               
00013Ar 1               check_zp:
00013Ar 1  A9 rr            lda     #<str_chk_zp
00013Cr 1  A2 rr            ldx     #>str_chk_zp
00013Er 1  20 rr rr         jsr     print_msg
000141r 1  A6 07            ldx     ZP_TMP
000143r 1  A9 AA            lda     #$AA
000145r 1  85 07            sta     ZP_TMP
000147r 1  C5 07            cmp     ZP_TMP
000149r 1  D0 0D            bne     chk_zp_fail
00014Br 1  A9 55            lda     #$55
00014Dr 1  85 07            sta     ZP_TMP
00014Fr 1  C5 07            cmp     ZP_TMP
000151r 1  D0 05            bne     chk_zp_fail
000153r 1  86 07            stx     ZP_TMP
000155r 1  4C rr rr         jmp     print_ok
000158r 1               chk_zp_fail:
000158r 1  86 07            stx     ZP_TMP
00015Ar 1  4C rr rr         jmp     print_fail
00015Dr 1               
00015Dr 1               check_stack:
00015Dr 1  A9 rr            lda     #<str_chk_stack
00015Fr 1  A2 rr            ldx     #>str_chk_stack
000161r 1  20 rr rr         jsr     print_msg
000164r 1  AE 80 01         ldx     STK_PROBE
000167r 1  A9 AA            lda     #$AA
000169r 1  8D 80 01         sta     STK_PROBE
00016Cr 1  CD 80 01         cmp     STK_PROBE
00016Fr 1  D0 10            bne     chk_stack_fail
000171r 1  A9 55            lda     #$55
000173r 1  8D 80 01         sta     STK_PROBE
000176r 1  CD 80 01         cmp     STK_PROBE
000179r 1  D0 06            bne     chk_stack_fail
00017Br 1  8E 80 01         stx     STK_PROBE
00017Er 1  4C rr rr         jmp     print_ok
000181r 1               chk_stack_fail:
000181r 1  8E 80 01         stx     STK_PROBE
000184r 1  4C rr rr         jmp     print_fail
000187r 1               
000187r 1               check_ram:
000187r 1  A9 rr            lda     #<str_chk_ram
000189r 1  A2 rr            ldx     #>str_chk_ram
00018Br 1  20 rr rr         jsr     print_msg
00018Er 1  AE 00 02         ldx     RAM_PROBE
000191r 1  A9 AA            lda     #$AA
000193r 1  8D 00 02         sta     RAM_PROBE
000196r 1  CD 00 02         cmp     RAM_PROBE
000199r 1  D0 10            bne     chk_ram_fail
00019Br 1  A9 55            lda     #$55
00019Dr 1  8D 00 02         sta     RAM_PROBE
0001A0r 1  CD 00 02         cmp     RAM_PROBE
0001A3r 1  D0 06            bne     chk_ram_fail
0001A5r 1  8E 00 02         stx     RAM_PROBE
0001A8r 1  4C rr rr         jmp     print_ok
0001ABr 1               chk_ram_fail:
0001ABr 1  8E 00 02         stx     RAM_PROBE
0001AEr 1  4C rr rr         jmp     print_fail
0001B1r 1               
0001B1r 1               check_vram:
0001B1r 1  A9 rr            lda     #<str_chk_vram
0001B3r 1  A2 rr            ldx     #>str_chk_vram
0001B5r 1  20 rr rr         jsr     print_msg
0001B8r 1  AE 68 81         ldx     VRAM_PROBE
0001BBr 1  A9 AA            lda     #$AA
0001BDr 1  8D 68 81         sta     VRAM_PROBE
0001C0r 1  CD 68 81         cmp     VRAM_PROBE
0001C3r 1  D0 10            bne     chk_vram_fail
0001C5r 1  A9 55            lda     #$55
0001C7r 1  8D 68 81         sta     VRAM_PROBE
0001CAr 1  CD 68 81         cmp     VRAM_PROBE
0001CDr 1  D0 06            bne     chk_vram_fail
0001CFr 1  8E 68 81         stx     VRAM_PROBE
0001D2r 1  4C rr rr         jmp     print_ok
0001D5r 1               chk_vram_fail:
0001D5r 1  8E 68 81         stx     VRAM_PROBE
0001D8r 1  4C rr rr         jmp     print_fail
0001DBr 1               
0001DBr 1               check_via:
0001DBr 1  A9 rr            lda     #<str_chk_via
0001DDr 1  A2 rr            ldx     #>str_chk_via
0001DFr 1  20 rr rr         jsr     print_msg
0001E2r 1  AD 0B 88         lda     VIA_ACR
0001E5r 1  C9 40            cmp     #$40
0001E7r 1  D0 11            bne     chk_via_fail
0001E9r 1  AD 0E 88         lda     VIA_IER
0001ECr 1  C9 C0            cmp     #$C0
0001EEr 1  D0 0A            bne     chk_via_fail
0001F0r 1  AD 02 88         lda     VIA_DDRB
0001F3r 1  C9 FF            cmp     #$FF
0001F5r 1  D0 03            bne     chk_via_fail
0001F7r 1  4C rr rr         jmp     print_ok
0001FAr 1               chk_via_fail:
0001FAr 1  4C rr rr         jmp     print_fail
0001FDr 1               
0001FDr 1               check_uart:
0001FDr 1  A9 rr            lda     #<str_chk_uart
0001FFr 1  A2 rr            ldx     #>str_chk_uart
000201r 1  20 rr rr         jsr     print_msg
000204r 1  AD 11 88         lda     UART_STATUS
000207r 1  29 80            and     #$80
000209r 1  D0 03            bne     chk_uart_fail
00020Br 1  4C rr rr         jmp     print_ok
00020Er 1               chk_uart_fail:
00020Er 1  4C rr rr         jmp     print_fail
000211r 1               
000211r 1               ; ============================================================
000211r 1               ;  IRQ HANDLER  (VIA Timer 1, ~750 Hz)
000211r 1               ; ============================================================
000211r 1               irq_handler:
000211r 1  48               pha
000212r 1  8A               txa
000213r 1  48               pha
000214r 1               
000214r 1  AD 04 88         lda     VIA_T1CL        ; clear T1 IRQ flag
000217r 1               
000217r 1  E6 00            inc     ZP_FAST
000219r 1  D0 22            bne     irq_done        ; only act every 256th IRQ
00021Br 1               
00021Br 1                   ; --- slow tick (~330 ms) ---
00021Br 1  E6 01            inc     ZP_TICK
00021Dr 1               
00021Dr 1                   ; toggle Port B bit 0 (LED blink)
00021Dr 1  AD 00 88         lda     VIA_ORB
000220r 1  49 01            eor     #$01
000222r 1  8D 00 88         sta     VIA_ORB
000225r 1               
000225r 1                   ; write high nibble of tick to row 8
000225r 1  A5 01            lda     ZP_TICK
000227r 1  4A               lsr
000228r 1  4A               lsr
000229r 1  4A               lsr
00022Ar 1  4A               lsr
00022Br 1  AA               tax
00022Cr 1  BD rr rr         lda     hex_table, x
00022Fr 1  8D 49 81         sta     VIA_HI
000232r 1               
000232r 1                   ; write low nibble of tick to row 8
000232r 1  A5 01            lda     ZP_TICK
000234r 1  29 0F            and     #$0F
000236r 1  AA               tax
000237r 1  BD rr rr         lda     hex_table, x
00023Ar 1  8D 4A 81         sta     VIA_LO
00023Dr 1               
00023Dr 1               irq_done:
00023Dr 1  68               pla
00023Er 1  AA               tax
00023Fr 1  68               pla
000240r 1  40               rti
000241r 1               
000241r 1               ; ============================================================
000241r 1               ;  put_char — write char in A to VIC at cursor position
000241r 1               ;  Handles: printable chars, CR ($0D), LF ($0A), BS ($08), DEL ($7F)
000241r 1               ;  Modifies: A, X, Y, ZP_CUR_LO, ZP_CUR_HI, ZP_COL
000241r 1               ; ============================================================
000241r 1               put_char:
000241r 1  C9 0D            cmp     #$0D            ; CR
000243r 1  F0 1B            beq     pc_newline
000245r 1  C9 0A            cmp     #$0A            ; LF
000247r 1  F0 17            beq     pc_newline
000249r 1  C9 08            cmp     #$08            ; backspace
00024Br 1  F0 36            beq     pc_backspace
00024Dr 1  C9 7F            cmp     #$7F            ; DEL (alternate backspace)
00024Fr 1  F0 32            beq     pc_backspace
000251r 1  C9 20            cmp     #$20            ; printable?
000253r 1  90 5E            bcc     pc_done         ; ignore other control chars
000255r 1               
000255r 1                   ; ---- write character at (ZP_CUR_HI:ZP_CUR_LO) + ZP_COL ----
000255r 1  A4 04            ldy     ZP_COL
000257r 1  91 02            sta     (ZP_CUR_LO),y
000259r 1  C8               iny
00025Ar 1  84 04            sty     ZP_COL
00025Cr 1  C0 28            cpy     #40             ; column overflow?
00025Er 1  90 53            bcc     pc_done
000260r 1               
000260r 1                   ; column reached 40 -> implicit newline
000260r 1               pc_newline:
000260r 1  A9 00            lda     #$00
000262r 1  85 04            sta     ZP_COL
000264r 1  18               clc
000265r 1  A5 02            lda     ZP_CUR_LO
000267r 1  69 28            adc     #40
000269r 1  85 02            sta     ZP_CUR_LO
00026Br 1  90 02            bcc     pc_check_end
00026Dr 1  E6 03            inc     ZP_CUR_HI
00026Fr 1               
00026Fr 1               pc_check_end:
00026Fr 1                   ; wrap if cursor >= INPUT_END ($83E8)
00026Fr 1  A5 03            lda     ZP_CUR_HI
000271r 1  C9 83            cmp     #>INPUT_END     ; compare high byte
000273r 1  90 3E            bcc     pc_done         ; < $83: still in range
000275r 1  D0 06            bne     pc_wrap         ; > $83: past end
000277r 1  A5 02            lda     ZP_CUR_LO
000279r 1  C9 E8            cmp     #<INPUT_END     ; compare low byte
00027Br 1  90 36            bcc     pc_done         ; still in row 24
00027Dr 1               pc_wrap:
00027Dr 1  20 rr rr         jsr     clear_input     ; clear input area and reset cursor
000280r 1  4C rr rr         jmp     pc_done
000283r 1               
000283r 1                   ; ---- backspace ----
000283r 1               pc_backspace:
000283r 1  A5 04            lda     ZP_COL
000285r 1  F0 0B            beq     pc_bs_prev_row
000287r 1                   ; step back within current row
000287r 1  C6 04            dec     ZP_COL
000289r 1  A4 04            ldy     ZP_COL
00028Br 1  A9 20            lda     #$20
00028Dr 1  91 02            sta     (ZP_CUR_LO),y
00028Fr 1  4C rr rr         jmp     pc_done
000292r 1               
000292r 1               pc_bs_prev_row:
000292r 1                   ; can't go before row 9
000292r 1  A5 02            lda     ZP_CUR_LO
000294r 1  C9 68            cmp     #<INPUT_ROW
000296r 1  D0 06            bne     pc_bs_go
000298r 1  A5 03            lda     ZP_CUR_HI
00029Ar 1  C9 81            cmp     #>INPUT_ROW
00029Cr 1  F0 15            beq     pc_done         ; already at top-left
00029Er 1               
00029Er 1               pc_bs_go:
00029Er 1  38               sec
00029Fr 1  A5 02            lda     ZP_CUR_LO
0002A1r 1  E9 28            sbc     #40
0002A3r 1  85 02            sta     ZP_CUR_LO
0002A5r 1  B0 02            bcs     pc_bs_no_borrow
0002A7r 1  C6 03            dec     ZP_CUR_HI
0002A9r 1               pc_bs_no_borrow:
0002A9r 1  A9 27            lda     #39
0002ABr 1  85 04            sta     ZP_COL
0002ADr 1  A0 27            ldy     #39
0002AFr 1  A9 20            lda     #$20
0002B1r 1  91 02            sta     (ZP_CUR_LO),y
0002B3r 1               
0002B3r 1               pc_done:
0002B3r 1  60               rts
