# GHDL simulation work files
work-*.cf
e~*.cf

# Generated wiki checkout (published by tools/publish_wiki.ps1)
.wiki/

# Generated simulation artifacts (built by make roms / make sd-boot-image)
sim/generated/

# ── PIX16 / Xilinx ISE ────────────────────────────────────────────────────────
# Keep: .xise project file, bitstreams/
# Ignore: everything ISE generates during synthesis & implementation
boards/pix16/project/xst/
boards/pix16/project/_ngo/
boards/pix16/project/_xmsgs/
boards/pix16/project/iseconfig/
boards/pix16/project/xlnx_auto_*
boards/pix16/project/*.ngd
boards/pix16/project/*.ngc
boards/pix16/project/*.ncd
boards/pix16/project/*.pcf
boards/pix16/project/*.bld
boards/pix16/project/*.mrp
boards/pix16/project/*.map
boards/pix16/project/*.par
boards/pix16/project/*.twr
boards/pix16/project/*.twx
boards/pix16/project/*.unroutes
boards/pix16/project/*.bit
boards/pix16/project/*.drc
boards/pix16/project/*.srp
boards/pix16/project/*.lso
boards/pix16/project/*.xrpt

# ── Tang Primer 20K / GowinEDA ────────────────────────────────────────────────
# Ignore the generated impl/ tree, but keep device.cfg under version control so
# the GUI (GOWIN FPGA Designer) gets the dual-purpose-pin settings (SSPI/MSPI as
# regular IO) without manual setup. A parent dir can't be re-included once
# ignored, so descend explicitly to the one tracked file.
boards/tang_primer_20k/sbc/project/impl/*
!boards/tang_primer_20k/sbc/project/impl/pnr/
boards/tang_primer_20k/sbc/project/impl/pnr/*
!boards/tang_primer_20k/sbc/project/impl/pnr/device.cfg
boards/tang_primer_20k/sbc/project/tmp/
boards/tang_primer_20k/sbc/project/*.gprj.user

# Generated Gowin IP elaboration/netlist files. Keep the editable .ipc and the
# synthesizable .v wrappers committed; these files are recreated by the IDE.
boards/tang_primer_20k/sbc/project/src/*/*.mod
boards/tang_primer_20k/sbc/project/src/*/*.vo
boards/tang_primer_20k/sbc/project/src/*/*_tmp.v
boards/tang_primer_20k/sbc/project/src/*/temp/

# Local copy of Sipeed's standalone DDR test used only during board bring-up.
boards/tang_primer_20k/diagnostics/ddr3_reference/

# ── REIST benchmark project (standalone) ──────────────────────────────────────
# Keep RTL, the Gowin projects (.gprj/.cst/.sdc/.tcl), and the IP .ipc/.v;
# drop the generated impl/ trees, per-user IDE state, and IP scratch files.
boards/tang_primer_20k/reist/impl/
boards/tang_primer_20k/reist/area/impl/
boards/tang_primer_20k/reist/*.gprj.user
boards/tang_primer_20k/reist/area/*.gprj.user
boards/tang_primer_20k/reist/src/*/*.mod
boards/tang_primer_20k/reist/src/*/*.vo
boards/tang_primer_20k/reist/src/*/*_tmp.v
boards/tang_primer_20k/reist/src/*/temp/





# ── Native C64 core ───────────────────────────────────────────────────────────
# Never commit the Commodore ROMs or anything that embeds them (copyright):
#   roms/c64/*            -- the raw BASIC/KERNAL/CHARGEN dumps you supply
#   rtl/c64/c64_roms.vhd  -- generated by tools/build_c64_roms.py from those dumps
#   c64 bitstreams (.fs)  -- the ROM data is synthesized into the bitstream
# See roms/c64/README.md for how to obtain/place the ROMs and regenerate.
boards/tang_primer_20k/c64/project/impl/
boards/tang_primer_20k/c64/bitstream/
boards/tang_primer_20k/c64/project/tmp/
boards/tang_primer_20k/c64/project/*.gprj.user
rtl/c64/c64_roms.vhd

roms/c64/*
!roms/c64/README.md

# ── Assembly build artifacts ───────────────────────────────────────────────────
sw/*.bin
sw/*.lst
sw/*.map
sw/*.o
sw/*.rom

# Local SID-analysis build products
tools/sid_dump_full.exe
tools/world_record_2_full.raw

# Local assistant/editor state and Python bytecode caches
.claude/
__pycache__/
*.py[cod]

sid_orig/

# Intermediate per-tune PRGs (regenerated from sid_orig by make tunes-d64 /
# sid-disks).  The packed .d64 images under roms/test_d64/ are committed instead.
roms/test_d64/prg/
roms/test_d64/sid/prg/
# Multi-part demo PRGs (regenerated by make multipart-d64); the .d64 is committed.
roms/test_d64/mp/

# Vendor datasheets / board schematics (large binaries) — kept locally,
# not tracked in the repo.
boards/tang_primer_20k/docs/

# Paper: track only the 6502 paper source and its built PDF; keep LaTeX
# build artefacts and any other local documents out of the repo.
paper/*
!paper/A 6502 Home Computer Rebuilt in Logic.tex
!paper/A 6502 Home Computer Rebuilt in Logic.pdf

# Image-display intermediates: the converter's working files and the per-bank
# split PRGs (regenerated by tools/build_image_disk.py).  The packed .d64 and
# the loader/converter sources are committed instead.
roms/_imgdisk/
sw/*_preview.png
sw/*_bg.inc

.tmp